<UserControl x:Class="FFBAnalyzer.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Left: Device panel ─────────────────────────────────── -->
        <Border Grid.Column="0" Background="{StaticResource BgPanel}"
                CornerRadius="8" Padding="16" Margin="0,0,12,0">
            <StackPanel>
                <TextBlock Text="Detected Devices" Style="{StaticResource H2}" Margin="0,0,0,12"/>

                <ComboBox ItemsSource="{Binding Devices}"
                          SelectedItem="{Binding SelectedDevice}"
                          DisplayMemberPath="Name"
                          Margin="0,0,0,8"/>

                <!-- Device info -->
                <Border Style="{StaticResource Card}" Visibility="{Binding SelectedDevice, Converter={StaticResource NullToCollapsed}}">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedDevice.Name}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Foreground="{StaticResource TextMuted}" Margin="0,4,0,0">
                            <Run Text="VID:"/>
                            <Run Text="{Binding SelectedDevice.VendorId, StringFormat=X4}"/>
                            <Run Text=" PID:"/>
                            <Run Text="{Binding SelectedDevice.ProductId, StringFormat=X4}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding SelectedDevice.TelemetryMode, StringFormat='Mode: {0}'}"
                                   Style="{StaticResource Muted}" Margin="0,2,0,0"/>
                        <TextBlock Text="{Binding SelectedDevice.InterfaceType, StringFormat='Interface: {0}'}"
                                   Style="{StaticResource Muted}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Button Content="Refresh Devices"
                        Style="{StaticResource SecondaryBtn}"
                        Command="{Binding RefreshDevicesAsyncCommand}"
                        Margin="0,4,0,0"/>

                <Separator Margin="0,16,0,16" Background="{StaticResource BgCard}"/>

                <!-- Status -->
                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource Muted}"
                           TextWrapping="Wrap"/>

                <!-- Loading indicator -->
                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,8,0,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisible}}"/>
            </StackPanel>
        </Border>

        <!-- ── Right: sessions + new session ─────────────────────── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header + new session button -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Recent Sessions" Style="{StaticResource H1}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="+ New Session"
                        Style="{StaticResource PrimaryBtn}"
                        Command="{Binding NewSessionCommand}"/>
            </Grid>

            <!-- Sessions list -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding RecentSessions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.OpenSessionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{Binding Description}"
                                                   Style="{StaticResource Muted}"
                                                   Margin="0,2,0,4"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Style="{StaticResource Muted}">
                                            <Run Text="{Binding Runs.Count}"/>
                                            <Run Text=" runs ·  "/>
                                            <Run Text="{Binding UpdatedAt, StringFormat='Updated {0:yyyy-MM-dd HH:mm}'}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="Open ›"
                                               Foreground="{StaticResource AccentBlue}"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
