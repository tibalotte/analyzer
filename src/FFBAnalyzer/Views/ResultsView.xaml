<UserControl x:Class="FFBAnalyzer.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="← Back"
                    Style="{StaticResource SecondaryBtn}"
                    Command="{Binding GoBackCommand}"
                    Margin="0,0,12,0"/>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource H1}">
                    <Run Text="{Binding Run.TestDefinition.Name}"/>
                    <Run Text=" – Results"/>
                </TextBlock>
                <TextBlock Style="{StaticResource Muted}">
                    <Run Text="{Binding Run.Device.Name}"/>
                    <Run Text=" · "/>
                    <Run Text="{Binding Run.Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"/>
                    <Run Text=" · "/>
                    <Run Text="{Binding Run.DisplayLabel}"/>
                </TextBlock>
            </StackPanel>
            <Button Grid.Column="2" Content="Export CSV"
                    Style="{StaticResource SecondaryBtn}"
                    Click="OnExportCsv"/>
        </Grid>

        <!-- Chart -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Signal vs Response"
                           Style="{StaticResource H2}" Margin="0,0,0,8"/>
                <lvc:CartesianChart Grid.Row="1"
                                    Series="{Binding ChartSeries}"
                                    XAxes="{Binding XAxes}"
                                    YAxes="{Binding YAxes}"
                                    LegendPosition="Top"
                                    Background="Transparent"
                                    MinHeight="200"/>
            </Grid>
        </Border>

        <!-- Metrics + interpretations -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Metrics table -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Metrics" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Metrics}"
                              CanUserSortColumns="True"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Metric"   Binding="{Binding DisplayName}" Width="*"/>
                            <DataGridTextColumn Header="Value"    Binding="{Binding Value, StringFormat=G5}" Width="120"/>
                            <DataGridTextColumn Header="Unit"     Binding="{Binding Unit}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Interpretations -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Interpretation" Style="{StaticResource H2}" Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding Interpretations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgPanel}"
                                        CornerRadius="4" Padding="10,6"
                                        Margin="0,0,0,6">
                                    <TextBlock Text="{Binding}"
                                               Foreground="{StaticResource AccentYellow}"
                                               TextWrapping="Wrap" FontSize="13"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="No notable observations."
                               Style="{StaticResource Muted}"
                               Visibility="{Binding Interpretations.Count,
                                            Converter={StaticResource ZeroToVisible}}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
