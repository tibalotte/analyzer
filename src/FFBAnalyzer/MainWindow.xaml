<Window x:Class="FFBAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FFBAnalyzer.ViewModels"
        xmlns:views="clr-namespace:FFBAnalyzer.Views"
        Title="FFB Analyzer – Wheel Comparison Tool"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDark}"
        Foreground="{StaticResource TextPrimary}">

    <!-- DataTemplates for navigation -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SessionViewModel}">
            <views:SessionView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TestWizardViewModel}">
            <views:TestWizardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ResultsViewModel}">
            <views:ResultsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ComparisonViewModel}">
            <views:ComparisonView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ExportImportViewModel}">
            <views:ExportImportView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>  <!-- Title bar / nav -->
            <RowDefinition Height="*"/>   <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ── Top bar ──────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo / app name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="FFB" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AccentBlue}"/>
                    <TextBlock Text=" Analyzer" FontSize="20" FontWeight="Light"
                               Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>

                <!-- Quick nav -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,0,0">
                    <Button Content="Home"
                            Style="{StaticResource SecondaryBtn}"
                            Command="{Binding NavigateHomeCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="Export / Import"
                            Style="{StaticResource SecondaryBtn}"
                            Command="{Binding NavigateToExportImportCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Main content (navigation) ───────────────────────────── -->
        <ContentControl Grid.Row="1"
                        Content="{Binding CurrentView}"
                        Margin="16"/>
    </Grid>
</Window>
